# Server Configuration
PORT=2121
PASV_MIN=7000
PASV_MAX=7010
# Public IP address of the server (for clients behind NAT). If not filled, the server will try to guess.
# PASV_URL=123.456.78.90
MAX_CONNECTIONS=100
IDLE_TIMEOUT=30000

# FTP Settings
GREETING="Welcome to BetterFTP Server v1.0"
ENABLE_ANONYMOUS=false

# Security (FTPS)
TLS_ENABLED=false
# Paths to certificates (absolute or relative to root)
# TLS_KEY_PATH=./certs/privkey.pem
# TLS_CERT_PATH=./certs/fullchain.pem

# Logging
LOG_LEVEL=debug

# Authentication Driver (json, sqlite, mysql, postgres)
AUTH_DRIVER=sqlite
# Hashing Algorithm (bcrypt, plain)
AUTH_HASHING=bcrypt

# Database Configuration (for sqlite, mysql, postgres)
# SQLite path relative to root or connection string for others
DB_CONNECTION=./dev.db
DB_TABLE=User
DB_COL_USER=username
DB_COL_PASS=password
DB_COL_HOME=directory

# JSON Configuration (if AUTH_DRIVER=json)
JSON_PATH=./users.json

# Quota (optional — leave unset to disable)
# QUOTA_MAX_FILE_SIZE=104857600   # Max bytes per single upload (e.g. 100 MB)
# QUOTA_MAX_TOTAL_SIZE=1073741824 # Max total bytes per user's home dir (e.g. 1 GB)
